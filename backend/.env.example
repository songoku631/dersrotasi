# Local development defaults. For Cloud Run, configure these as environment
# variables (or mount secrets) instead of copying this file.
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:5176

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dersrotasi
DB_USERNAME=root
DB_PASSWORD=

FIREBASE_PROJECT_ID=ders-rotasi
# Optional: absolute path to a service-account JSON file when a future
# Firebase Admin SDK integration requires it. Never commit that file.
FIREBASE_CREDENTIALS_PATH=

# Windows local development only. Leave empty on Cloud Run so PHP/Guzzle uses
# the operating system certificate store.
SSL_CA_BUNDLE=C:\php\cacert.pem

# YÖK Atlas veri aracı için dürüst kimlik. Büyük çalıştırma öncesinde localhost
# bölümünü projenizin herkese açık adresi veya iletişim sayfasıyla değiştirin.
YOKATLAS_USER_AGENT="DersRotasiDataTool/1.0 (+http://localhost)"
