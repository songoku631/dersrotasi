{
  "name": "dersrotasi/backend",
  "description": "Ders Rotası PHP API",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "firebase/php-jwt": "^7.1",
    "guzzlehttp/guzzle": "^7.9",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "DersRotasi\\": "src/"
    }
  },
  "scripts": {
    "migrate": "php database/migrate.php"
  },
  "config": {
    "sort-packages": true
  }
}
